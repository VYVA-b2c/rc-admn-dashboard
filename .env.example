# Server-only database connection for the Replit backend.
# Set this in Replit Secrets / Deployment Secrets, not in client-side VITE_* variables.
LOVABLE_DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Keep browser API calls same-origin in production unless you intentionally split the API.
# VITE_API_BASE_URL=
