# Server-only database connection for the Replit backend.
# Replit Database normally provides DATABASE_URL automatically.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Keep browser API calls same-origin in production unless you intentionally split the API.
# VITE_API_BASE_URL=

# Server-side upstream used for live VYVA user/profile/medication reads.
# No browser secret is required for this API.
VYVA_BACKEND_API_URL=https://api.vyva.io

# Server-only secret used to sign Replit-backed console magic links.
# Set this to a long random value in production.
# CONSOLE_SESSION_SECRET=replace-with-a-long-random-secret

# Team invite emails are rendered and sent by the Replit backend.
# Choose one provider key and use a sender address from a verified sending domain.
# RESEND_API_KEY=re_xxx
# SENDGRID_API_KEY=SG.xxx
# POSTMARK_SERVER_TOKEN=postmark_xxx
# TEAM_INVITE_EMAIL_FROM="VYVA <no-reply@vyva.life>"
# TEAM_INVITE_EMAIL_REPLY_TO=support@vyva.life

# Used in invite links and guide links. Set this to the deployed Replit app URL.
# PUBLIC_APP_URL=https://your-app.replit.app

# Optional overrides. By default invite links land on the dashboard.
# TEAM_INVITE_REDIRECT_PATH=/
# TEAM_INVITE_GUIDE_PATH=/guide/team-access
# TEAM_INVITE_GUIDE_URL=https://your-app.replit.app/guide/team-access
